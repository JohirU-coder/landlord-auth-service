{
  "name": "landlord-auth-service",
  "version": "2.0.0",
  "description": "Secure authentication service for RentReviews platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --coverage",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "db:setup:test": "node scripts/setup_test_db.js",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "modulePathIgnorePatterns": ["<rootDir>/rentreviews-platform/"],
    "testPathIgnorePatterns": ["<rootDir>/rentreviews-platform/"]
  },
  "keywords": [
    "authentication",
    "jwt",
    "security",
    "rentals"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^6.11.2",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "resend": "^4.8.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=24.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JohirU-coder/landlord-auth-service.git"
  }
}
