{
  "name": "landlord-auth-service",
  "version": "2.0.0",
  "description": "Secure authentication service for RentReviews platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --coverage",
    "audit": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "db:setup:test": "node scripts/setup_test_db.js",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "modulePathIgnorePatterns": ["<rootDir>/rentreviews-platform/"],
    "testPathIgnorePatterns": ["<rootDir>/rentreviews-platform/"]
  },
  "keywords": [
    "authentication",
    "jwt",
    "security",
    "rentals"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JohirU-coder/landlord-auth-service.git"
  }
}
