# ============================================================
# Root Auth Service — Required Environment Variables
# Copy this file to .env (never commit .env to git)
# Generate JWT_SECRET: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ============================================================

# Server
PORT=8080
NODE_ENV=production

# JWT — must be 32+ random characters, identical across all services
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# PostgreSQL — full connection string including credentials
# SSL is required in production; Railway format example below
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# CORS — your production frontend URL (e.g. the Railway static site URL)
FRONTEND_URL=https://your-frontend-domain.com

# Resend email service — sign up at resend.com (free tier: 3,000 emails/month)
# If omitted, email links are printed to console (dev mode)
RESEND_API_KEY=re_REPLACE_WITH_YOUR_RESEND_API_KEY
FROM_EMAIL=RentReviews <noreply@yourdomain.com>

# Admin secret — required to call /setup-database, /migrate, /check-schema
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# Test database (used by Jest — defaults to localhost if not set)
# TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rentreviews_test
