# ============================================================
# Property Service — Required Environment Variables
# Copy this file to .env (never commit .env to git)
# Generate JWT_SECRET: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ============================================================

# Server
PORT=8080
NODE_ENV=production

# JWT — must be 32+ random characters, IDENTICAL across auth, property, and review services
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS

# PostgreSQL — full connection string including credentials
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
